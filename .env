# ── Dono do sistema ────────────────────────────
NUMERO_DONO=5541999999999        # Seu número com DDI+DDD, sem espaços
NOME_DONO=Rodrigo

# ── Número de teste (opcional) ─────────────────
# Quando preenchido, o bot só responde esse número
NUMERO_TESTE=

# ── Chaves de API de Inteligência Artificial ───
# Obtenha a do Claude em: https://console.anthropic.com
ANTHROPIC_KEY=sk-ant-...
# Obtenha a do Gemini em: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ── Google OAuth (painel web) ──────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Credenciais do Painel Web ──────────────────
ADMIN_EMAIL=seu@email.com
ADMIN_PASSWORD=suasenha

# ── Ngrok ──────────────────────────────────────
# Cole o domínio reservado no painel ngrok (sem https://)
NGROK_DOMAIN=seu-dominio.ngrok-free.app
# Cole o seu authtoken do Ngrok abaixo
NGROK_AUTHTOKEN=

# ── Configurações internas ─────────────────────
API_PORT=8000
API_BASE_URL=http://localhost:8000
TZ=America/Sao_Paulo

# ── Modo de exibição ───────────────────────────
# 1 = janelas minimizadas | 0 = modo fantasma (sem janelas)
CMD=1
